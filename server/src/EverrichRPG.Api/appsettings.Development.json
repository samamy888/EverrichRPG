{
  "ConnectionStrings": {
    "GameDatabase": "Data Source=everrich-rpg-dev.db"
  },
  "Database": {
    "Provider": "Sqlite",
    "ApplyMigrations": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/app-.clef",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "shared": true,
          "flushToDiskInterval": "00:00:02"
        }
      }
    ]
  },
  "Diagnostics": {
    "LogAccessToken": "local-dev"
  }
}
