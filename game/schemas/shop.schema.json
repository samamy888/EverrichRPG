{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://everrich.local/schemas/shop.schema.json",
  "title": "EVERRICH RPG Shop",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "nameKey",
    "categories",
    "regionId",
    "clerkCharacterId",
    "brandId",
    "licenseStatus"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "nameKey": { "type": "string", "minLength": 1 },
    "categories": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["beauty", "perfume", "liquor", "food", "souvenir", "fashion", "travel", "other"]
      }
    },
    "regionId": { "type": "string", "minLength": 1 },
    "clerkCharacterId": { "type": "string", "minLength": 1 },
    "brandId": { "type": "string", "minLength": 1 },
    "licenseStatus": {
      "enum": ["approved", "review-required", "placeholder-only"]
    }
  }
}
