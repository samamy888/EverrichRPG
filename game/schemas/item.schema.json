{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://everrich.local/schemas/item.schema.json",
  "title": "EVERRICH RPG Item",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "nameKey",
    "category",
    "brandId",
    "price",
    "weight",
    "volume",
    "tags",
    "storeIds",
    "licenseStatus"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "nameKey": { "type": "string", "minLength": 1 },
    "descriptionKey": { "type": ["string", "null"] },
    "category": {
      "enum": ["beauty", "perfume", "liquor", "food", "souvenir", "fashion", "travel", "other"]
    },
    "brandId": { "type": "string", "minLength": 1 },
    "price": { "type": "integer", "minimum": 0 },
    "weight": { "type": "integer", "minimum": 0 },
    "volume": { "type": "integer", "minimum": 0 },
    "tags": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "storeIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "catalogId": { "type": ["string", "null"] },
    "licenseStatus": {
      "enum": ["approved", "review-required", "placeholder-only"]
    },
    "sourceReference": { "type": ["string", "null"] }
  }
}
