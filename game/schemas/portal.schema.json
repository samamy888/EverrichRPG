{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://everrich.local/schemas/portal.schema.json",
  "title": "EVERRICH RPG Portal",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "bounds", "destination", "transition"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "type": { "const": "portal" },
    "bounds": { "$ref": "#/$defs/rectangle" },
    "destination": {
      "type": "object",
      "additionalProperties": false,
      "required": ["regionId", "spawnId", "facing"],
      "properties": {
        "regionId": { "type": "string", "minLength": 1 },
        "spawnId": { "type": "string", "minLength": 1 },
        "facing": { "enum": ["up", "down", "left", "right"] }
      }
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "durationMs"],
      "properties": {
        "type": { "const": "fade" },
        "durationMs": { "type": "integer", "minimum": 0, "maximum": 2000 }
      }
    },
    "cooldownMs": { "type": "integer", "minimum": 0, "default": 350 },
    "requiredFlag": { "type": ["string", "null"] }
  },
  "$defs": {
    "rectangle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
