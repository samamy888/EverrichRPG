{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://everrich.local/schemas/world-topology.schema.json",
  "title": "EVERRICH RPG World Topology",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "startRegionId", "regions", "connections"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "startRegionId": { "type": "string", "minLength": 1 },
    "regions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "nameKey", "kind", "enabledInMvp"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "nameKey": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["hub", "shop", "service", "event", "future"] },
          "enabledInMvp": { "type": "boolean" }
        }
      }
    },
    "connections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "fromRegionId", "toRegionId", "bidirectional", "transition"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "fromRegionId": { "type": "string", "minLength": 1 },
          "toRegionId": { "type": "string", "minLength": 1 },
          "bidirectional": { "type": "boolean" },
          "transition": { "const": "fade" }
        }
      }
    }
  }
}
