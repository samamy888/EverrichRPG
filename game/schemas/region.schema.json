{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://everrich.local/schemas/region.schema.json",
  "title": "Everrich RPG Region",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "nameKey",
    "kind",
    "width",
    "height",
    "tileSize",
    "tilesetIds",
    "defaultSpawnId",
    "cameraMode"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "nameKey": { "type": "string", "minLength": 1 },
    "kind": {
      "enum": ["hub", "shop", "service", "event", "future"]
    },
    "width": { "type": "integer", "minimum": 8 },
    "height": { "type": "integer", "minimum": 8 },
    "tileSize": { "const": 16 },
    "tilesetIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "musicId": { "type": ["string", "null"] },
    "ambientId": { "type": ["string", "null"] },
    "defaultSpawnId": { "type": "string", "minLength": 1 },
    "cameraMode": { "const": "follow-player" },
    "enabledInMvp": { "type": "boolean" },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
