{
  "name": "everrich-rpg-rewrite",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:iis": "npm run build && node scripts/copy-web-config.mjs",
    "map:slice": "python scripts/slice-map-tiles.py --input public/assets/map/village-base.png --output-dir public/assets/map/terminal/tiles --tile-size 128 --meta-output public/assets/map/terminal/chunks-meta.json --url-base /assets/map/terminal/tiles",
    "migration:inventory": "node scripts/build-migration-inventory.mjs",
    "phase0:verify": "npm run migration:inventory && node scripts/verify-phase0-data.mjs",
    "world:verify": "node scripts/verify-world-data.mjs",
    "tiled:bootstrap": "python scripts/bootstrap-tiled-maps.py",
    "tiled:departure": "node scripts/generate-departure-hall-maps.mjs",
    "tiled:ivory-walls": "node scripts/apply-ivory-walls.mjs",
    "tiled:quest-dialogue": "node scripts/apply-quest-dialogue.mjs",
    "tiled:effects": "node scripts/apply-environment-effects.mjs",
    "assets:planters": "python scripts/build-planter-animations.py",
    "assets:bitmap-font": "python scripts/build-bitmap-font.py",
    "tiled:animated-assets": "node scripts/apply-animated-assets.mjs && node scripts/apply-shop-staff.mjs",
    "tiled:terminal-details": "node scripts/apply-terminal-details.mjs",
    "tiled:shop-staff": "node scripts/apply-shop-staff.mjs",
    "tiled:remove-fixed-travelers": "node scripts/remove-fixed-travelers.mjs",
    "tiled:orient-props": "node scripts/orient-tiled-props.mjs",
    "tiled:verify": "node scripts/verify-tiled-maps.mjs",
    "shop:verify": "node scripts/verify-shop-data.mjs",
    "exploration:verify": "node scripts/verify-exploration-data.mjs",
    "character:verify": "node scripts/verify-character-assets.mjs",
    "release:prep": "npm run map:slice && npm run world:verify && npm run build:iis",
    "preview": "vite preview",
    "test": "vitest run",
    "test:traveler": "vitest run src/systems/TravelerPopulation.test.ts",
    "test:animation": "vitest run src/animation/AnimationRegistry.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "typescript": "^5.9.2",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
