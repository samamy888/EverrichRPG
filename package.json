{
  "name": "everrich-rpg",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "backend:dev": "vite --config backend/vite.config.ts",
    "backend:typecheck": "tsc -p backend/tsconfig.json --noEmit",
    "backend:build": "npm run backend:typecheck && vite build --config backend/vite.config.ts",
    "build:iis": "npm run build && npm run backend:build && node scripts/copy-web-config.mjs"
  },
  "devDependencies": {
    "typescript": "^5.9.2",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
